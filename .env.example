# Postgres connection. In Railway, this is auto-injected by the Postgres plugin.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fpvdle?schema=public"

# Admin auth
ADMIN_USERNAME="admin"
# Generate with: npm run hash-password -- 'your-password'
ADMIN_PASSWORD_HASH="$2a$10$REPLACE_ME"
# Random string, e.g. `openssl rand -base64 48`
JWT_SECRET="change-me-to-a-long-random-string"

# Where uploaded media is stored on disk.
# Local dev: ./data/media
# Railway:   /data/media (volume mount)
MEDIA_DIR="./data/media"
